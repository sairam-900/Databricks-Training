-- ==========================================
-- INTERMEDIATE - UNION ALL
-- ==========================================

-- 106. Count total rows returned using UNION ALL.
SELECT COUNT(*) AS TotalRows
FROM
(
    SELECT EmployeeID
    FROM CurrentEmployees

    UNION ALL

    SELECT EmployeeID
    FROM FormerEmployees
) AS EmployeeList;

